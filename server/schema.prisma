// Prisma schema for PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  accountId String
  imageUrl  String
  joinedAt  DateTime @default(now())
  status    UserStatus
  trips     Trip[]
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

model Trip {
  id         String      @id @default(uuid())
  tripDetail String
  createdAt  DateTime    @default(now())
  payment_link String
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  images     TripImage[]
}

model TripImage {
  id      String   @id @default(uuid())
  imageUrl String
  tripId  String
  trip    Trip     @relation(fields: [tripId], references: [id])
}
